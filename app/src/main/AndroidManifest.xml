<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="36" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="36" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DormManager"
        android:usesCleartextTraffic="true"
        tools:targetApi="36">


        <!-- Splash Activity - Entry Point -->
        <activity
            android:name=".ui.auth.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Activity -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait" />

        <!-- Register Activity -->
        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait" />

        <!-- Profile Activity -->
        <activity
            android:name=".ui.auth.ProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait" />

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait" />

        <!-- Payments Activities -->
        <activity
            android:name=".ui.payments.PaymentsActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.payments.CreatePaymentActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.payments.PaymentDetailsActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait" />

        <!-- Issues Activities -->
        <activity
            android:name=".ui.issues.IssuesActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.issues.CreateIssueActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.issues.IssueDetailsActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait" />

        <!-- Reservations Activities -->
        <activity
            android:name=".ui.reservations.ReservationsActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.reservations.CreateReservationActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.reservations.ReservationDetailsActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.reservations.ResourcesActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait" />

        <!-- Key Management Activities -->
        <activity
            android:name=".ui.keys.KeysActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.keys.KeyAssignmentDetailsActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait" />

        <!-- Messages -->
        <activity android:name=".ui.messages.MessagesActivity" android:exported="false" android:theme="@style/Theme.DormManager" android:screenOrientation="portrait" android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ui.messages.SendMessageActivity" android:exported="false" android:theme="@style/Theme.DormManager" android:screenOrientation="portrait" />
        <activity android:name=".ui.messages.MessageDetailsActivity" android:exported="false" android:theme="@style/Theme.DormManager" android:screenOrientation="portrait" />

        <!-- Announcements -->
        <activity
            android:name=".ui.announcements.AnnouncementsActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait"
            android:configChanges="uiMode" />
        <activity
            android:name=".ui.announcements.AnnouncementDetailsActivity"
            android:exported="false"
            android:theme="@style/Theme.DormManager"
            android:screenOrientation="portrait"
            android:configChanges="uiMode" />

        <!-- FileProvider for PDF viewing and file operations -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />

    </application>

</manifest>