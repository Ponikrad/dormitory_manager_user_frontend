<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark Theme - Material Design 3 -->
    <style name="Base.Theme.DormManager" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/md_theme_dark_primary</item>
        <item name="colorOnPrimary">@color/md_theme_dark_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_dark_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_dark_onPrimaryContainer</item>

        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/md_theme_dark_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_dark_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_dark_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_dark_onSecondaryContainer</item>

        <!-- Tertiary Colors -->
        <item name="colorTertiary">@color/md_theme_dark_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_dark_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_dark_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_dark_onTertiaryContainer</item>

        <!-- Error Colors -->
        <item name="colorError">@color/md_theme_dark_error</item>
        <item name="colorOnError">@color/md_theme_dark_onError</item>
        <item name="colorErrorContainer">@color/md_theme_dark_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_theme_dark_onErrorContainer</item>

        <!-- Background Colors -->
        <item name="android:colorBackground">@color/md_theme_dark_background</item>
        <item name="colorOnBackground">@color/md_theme_dark_onBackground</item>
        <item name="colorSurface">@color/md_theme_dark_surface</item>
        <item name="colorOnSurface">@color/md_theme_dark_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_dark_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_dark_onSurfaceVariant</item>

        <!-- Outline -->
        <item name="colorOutline">@color/md_theme_dark_outline</item>

        <!-- Inverse Colors -->
        <item name="colorSurfaceInverse">@color/md_theme_dark_inverseSurface</item>
        <item name="colorOnSurfaceInverse">@color/md_theme_dark_inverseOnSurface</item>
        <item name="colorPrimaryInverse">@color/md_theme_dark_inversePrimary</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Typography -->
        <item name="fontFamily">@font/roboto</item>
        <item name="android:fontFamily">@font/roboto</item>
    </style>

    <style name="Theme.DormManager" parent="Base.Theme.DormManager" />

    <!-- ============================================ -->
    <!-- BUTTON STYLES -->
    <!-- ============================================ -->

    <style name="Widget.DormManager.Button" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/md_theme_dark_onPrimary</item>
        <item name="backgroundTint">@color/md_theme_dark_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="fontFamily">@font/roboto_medium</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="elevation">2dp</item>
    </style>

    <style name="Widget.DormManager.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/md_theme_dark_primary</item>
        <item name="strokeColor">@color/md_theme_dark_outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="fontFamily">@font/roboto_medium</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="Widget.DormManager.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textColor">@color/md_theme_dark_onSecondaryContainer</item>
        <item name="backgroundTint">@color/md_theme_dark_secondaryContainer</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="fontFamily">@font/roboto_medium</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- ============================================ -->
    <!-- CARD STYLES -->
    <!-- ============================================ -->

    <style name="Widget.DormManager.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="contentPadding">0dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.DormManager.Card.Filled" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">?attr/colorSurfaceVariant</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="contentPadding">0dp</item>
    </style>

    <style name="Widget.DormManager.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="contentPadding">0dp</item>
    </style>

    <!-- ============================================ -->
    <!-- TEXT INPUT STYLES -->
    <!-- ============================================ -->

    <style name="Widget.DormManager.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/md_theme_dark_primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/md_theme_dark_primary</item>
        <item name="android:textColorHint">@color/md_theme_dark_onSurfaceVariant</item>
        <item name="helperTextTextColor">@color/md_theme_dark_onSurfaceVariant</item>
        <item name="errorTextColor">@color/md_theme_dark_error</item>
    </style>

    <!-- ============================================ -->
    <!-- CHIP STYLES -->
    <!-- ============================================ -->

    <style name="Widget.DormManager.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">8dp</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/md_theme_dark_onSurfaceVariant</item>
        <item name="chipBackgroundColor">@color/md_theme_dark_surface</item>
        <item name="chipStrokeColor">@color/md_theme_dark_outline</item>
        <item name="checkedIconTint">@color/md_theme_dark_primary</item>
    </style>

    <style name="Widget.DormManager.Chip.Assist" parent="Widget.Material3.Chip.Assist">
        <item name="chipCornerRadius">8dp</item>
        <item name="android:textSize">12sp</item>
        <item name="chipMinHeight">28dp</item>
    </style>

    <!-- ============================================ -->
    <!-- FAB STYLES -->
    <!-- ============================================ -->

    <style name="Widget.DormManager.ExtendedFloatingActionButton" parent="Widget.Material3.ExtendedFloatingActionButton.Primary">
        <item name="backgroundTint">@color/md_theme_dark_primaryContainer</item>
        <item name="android:textColor">@color/md_theme_dark_onPrimaryContainer</item>
        <item name="iconTint">@color/md_theme_dark_onPrimaryContainer</item>
        <item name="elevation">3dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.DormManager.SmallComponent</item>
    </style>

    <!-- Typography styles are inherited from light theme -->

</resources>