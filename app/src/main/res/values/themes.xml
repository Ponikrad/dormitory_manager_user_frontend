<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Light Theme - Material Design 3 -->
    <style name="Base.Theme.DormManager" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>

        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_light_onSecondaryContainer</item>

        <!-- Tertiary Colors -->
        <item name="colorTertiary">@color/md_theme_light_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_light_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_light_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_light_onTertiaryContainer</item>

        <!-- Error Colors -->
        <item name="colorError">@color/md_theme_light_error</item>
        <item name="colorOnError">@color/md_theme_light_onError</item>
        <item name="colorErrorContainer">@color/md_theme_light_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_theme_light_onErrorContainer</item>

        <!-- Background Colors -->
        <item name="android:colorBackground">@color/md_theme_light_background</item>
        <item name="colorOnBackground">@color/md_theme_light_onBackground</item>
        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_light_onSurfaceVariant</item>

        <!-- Outline -->
        <item name="colorOutline">@color/md_theme_light_outline</item>

        <!-- Inverse Colors -->
        <item name="colorSurfaceInverse">@color/md_theme_light_inverseSurface</item>
        <item name="colorOnSurfaceInverse">@color/md_theme_light_inverseOnSurface</item>
        <item name="colorPrimaryInverse">@color/md_theme_light_inversePrimary</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Typography -->
        <item name="fontFamily">@font/roboto</item>
        <item name="android:fontFamily">@font/roboto</item>
    </style>

    <style name="Theme.DormManager" parent="Base.Theme.DormManager" />

    <!-- ============================================ -->
    <!-- BUTTON STYLES -->
    <!-- ============================================ -->

    <style name="Widget.DormManager.Button" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/md_theme_light_onPrimary</item>
        <item name="backgroundTint">@color/md_theme_light_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="fontFamily">@font/roboto_medium</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="elevation">2dp</item>
    </style>

    <style name="Widget.DormManager.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/md_theme_light_primary</item>
        <item name="strokeColor">@color/md_theme_light_outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="fontFamily">@font/roboto_medium</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="Widget.DormManager.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textColor">@color/md_theme_light_onSecondaryContainer</item>
        <item name="backgroundTint">@color/md_theme_light_secondaryContainer</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="fontFamily">@font/roboto_medium</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- ============================================ -->
    <!-- CARD STYLES -->
    <!-- ============================================ -->

    <style name="Widget.DormManager.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="cardElevation">1dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="contentPadding">0dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.DormManager.Card.Filled" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">?attr/colorSurfaceVariant</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="contentPadding">0dp</item>
    </style>

    <style name="Widget.DormManager.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="contentPadding">0dp</item>
    </style>

    <!-- ============================================ -->
    <!-- TEXT INPUT STYLES -->
    <!-- ============================================ -->

    <style name="Widget.DormManager.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/md_theme_light_primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/md_theme_light_primary</item>
        <item name="android:textColorHint">@color/md_theme_light_onSurfaceVariant</item>
        <item name="helperTextTextColor">@color/md_theme_light_onSurfaceVariant</item>
        <item name="errorTextColor">@color/md_theme_light_error</item>
    </style>

    <!-- ============================================ -->
    <!-- CHIP STYLES -->
    <!-- ============================================ -->

    <style name="Widget.DormManager.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">8dp</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/md_theme_light_onSurfaceVariant</item>
        <item name="chipBackgroundColor">@color/md_theme_light_surface</item>
        <item name="chipStrokeColor">@color/md_theme_light_outline</item>
        <item name="checkedIconTint">@color/md_theme_light_primary</item>
    </style>

    <style name="Widget.DormManager.Chip.Assist" parent="Widget.Material3.Chip.Assist">
        <item name="chipCornerRadius">8dp</item>
        <item name="android:textSize">12sp</item>
        <item name="chipMinHeight">28dp</item>
    </style>

    <!-- ============================================ -->
    <!-- TEXT APPEARANCE STYLES -->
    <!-- ============================================ -->

    <style name="TextAppearance.DormManager.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">@font/roboto</item>
        <item name="android:textSize">57sp</item>
        <item name="lineHeight">64sp</item>
        <item name="android:letterSpacing">-0.0025</item>
    </style>

    <style name="TextAppearance.DormManager.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="fontFamily">@font/roboto</item>
        <item name="android:textSize">45sp</item>
        <item name="lineHeight">52sp</item>
    </style>

    <style name="TextAppearance.DormManager.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">@font/roboto</item>
        <item name="android:textSize">32sp</item>
        <item name="lineHeight">40sp</item>
    </style>

    <style name="TextAppearance.DormManager.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/roboto_medium</item>
        <item name="android:textSize">28sp</item>
        <item name="lineHeight">36sp</item>
    </style>

    <style name="TextAppearance.DormManager.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">@font/roboto_medium</item>
        <item name="android:textSize">24sp</item>
        <item name="lineHeight">32sp</item>
    </style>

    <style name="TextAppearance.DormManager.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/roboto_medium</item>
        <item name="android:textSize">22sp</item>
        <item name="lineHeight">28sp</item>
    </style>

    <style name="TextAppearance.DormManager.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">@font/roboto_medium</item>
        <item name="android:textSize">16sp</item>
        <item name="lineHeight">24sp</item>
        <item name="android:letterSpacing">0.0015</item>
    </style>

    <style name="TextAppearance.DormManager.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="fontFamily">@font/roboto_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="lineHeight">20sp</item>
        <item name="android:letterSpacing">0.001</item>
    </style>

    <style name="TextAppearance.DormManager.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/roboto</item>
        <item name="android:textSize">16sp</item>
        <item name="lineHeight">24sp</item>
        <item name="android:letterSpacing">0.005</item>
    </style>

    <style name="TextAppearance.DormManager.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/roboto</item>
        <item name="android:textSize">14sp</item>
        <item name="lineHeight">20sp</item>
        <item name="android:letterSpacing">0.0025</item>
    </style>

    <style name="TextAppearance.DormManager.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">@font/roboto</item>
        <item name="android:textSize">12sp</item>
        <item name="lineHeight">16sp</item>
        <item name="android:letterSpacing">0.004</item>
    </style>

    <style name="TextAppearance.DormManager.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/roboto_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="lineHeight">20sp</item>
        <item name="android:letterSpacing">0.001</item>
    </style>

    <style name="TextAppearance.DormManager.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">@font/roboto_medium</item>
        <item name="android:textSize">12sp</item>
        <item name="lineHeight">16sp</item>
        <item name="android:letterSpacing">0.005</item>
    </style>

    <style name="TextAppearance.DormManager.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">@font/roboto_medium</item>
        <item name="android:textSize">11sp</item>
        <item name="lineHeight">16sp</item>
        <item name="android:letterSpacing">0.005</item>
    </style>

    <!-- Legacy Compatibility -->
    <style name="TextAppearance.DormManager.Headline1" parent="TextAppearance.DormManager.HeadlineLarge" />
    <style name="TextAppearance.DormManager.Headline2" parent="TextAppearance.DormManager.HeadlineMedium" />
    <style name="TextAppearance.DormManager.Body" parent="TextAppearance.DormManager.BodyLarge" />
    <style name="TextAppearance.DormManager.Caption" parent="TextAppearance.DormManager.BodySmall" />
    <style name="TextAppearance.DormManager" parent="TextAppearance.DormManager.BodyLarge" />

    <!-- ============================================ -->
    <!-- FAB STYLES -->
    <!-- ============================================ -->

    <style name="Widget.DormManager.ExtendedFloatingActionButton" parent="Widget.Material3.ExtendedFloatingActionButton.Primary">
        <item name="backgroundTint">@color/md_theme_light_primaryContainer</item>
        <item name="android:textColor">@color/md_theme_light_onPrimaryContainer</item>
        <item name="iconTint">@color/md_theme_light_onPrimaryContainer</item>
        <item name="elevation">3dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.DormManager.SmallComponent</item>
    </style>

    <!-- ============================================ -->
    <!-- SHAPE STYLES -->
    <!-- ============================================ -->

    <style name="ShapeAppearance.DormManager.SmallComponent" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.DormManager.MediumComponent" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.DormManager.LargeComponent" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

</resources>